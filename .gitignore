# Data layers (medallion) — never commit raw/intermediate data
data/bronze/
data/silver/
data/gold/
data/_metadata/

# Raw data files in root (partner-provided, too large for git)
*.zip
outputs/

# Python
__pycache__/
*.pyc
.venv/
.ruff_cache/
.pytest_cache/
*.egg-info/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Secrets — credenciales CDSE u otras (nunca commitear)
.env
.env.*

